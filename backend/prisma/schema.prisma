generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id                 String         @id @default(cuid())
  employeeCode       String         @unique
  firstName          String
  lastName           String
  email              String?        @unique
  loginEmail         String?        @unique
  passwordHash       String?
  role               String         @default("EMPLOYEE")
  accessEnabled      Boolean        @default(false)
  phone              String?
  dateOfBirth        DateTime?
  dateOfJoining      DateTime
  designation        String
  department         String
  nationality        String?
  emiratesId         String?
  passportNumber     String?
  managerId          String?
  employmentType     String
  workMode           String         @default("OFFICE")
  officeId           String?
  faceAuthEnabled    Boolean        @default(true)
  faceDescriptor     Json?
  faceEnrolledAt     DateTime?
  basicSalary        Float          @default(0)
  housingAllowance   Float          @default(0)
  transportAllowance Float          @default(0)
  iban               String?
  bankName           String?
  wpsEnabled         Boolean        @default(true)
  labourCardNumber   String?
  noticePeriodDays   Int            @default(30)
  status             String         @default("ACTIVE")
  legacyEmpId        String?
  gender             String?
  maritalStatus      String?
  category           String?
  subCategory        String?
  grade              String?
  employeeType       String?
  businessUnit       String?
  division           String?
  workLocation       String?
  workCountry        String?
  payrollType        String?
  payrollStatus      String?
  payrollDivision    String?
  conveyanceAllowance    Float          @default(0)
  fixedOtAllowance       Float          @default(0)
  foodAllowance          Float          @default(0)
  otherAllowance         Float          @default(0)
  overseasAllowance      Float          @default(0)
  performanceAllowance   Float          @default(0)
  petrolAllowance        Float          @default(0)
  riskAllowance          Float          @default(0)
  socialInsurance        Float          @default(0)
  telephoneAllowance     Float          @default(0)
  vehicleAllowance       Float          @default(0)
  kidsEducationAllowance Float          @default(0)
  grossSalary            Float          @default(0)
  otEligible             String?
  otRuleNormal           Float          @default(0)
  netPayCurrency         String         @default("AED")
  visaType               String?
  visaSponsor            String?
  hodName                String?
  hodEmail               String?
  comments               String?
  probationStatus        String?
  joiningMonth           String?
  probationCompletionDate DateTime?
  ctcMonth               Float?
  ctcYear                Float?
  cancellationType       String?
  lastWorkingDate        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  manager          Employee?      @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates     Employee[]     @relation("ManagerSubordinates")
  office           Office?        @relation(fields: [officeId], references: [id])
  leaveBalances    LeaveBalance[]
  leaveRequests    LeaveRequest[] @relation("RequestedBy")
  l1Approvals      LeaveRequest[] @relation("ApprovedByL1")
  l2Approvals      LeaveRequest[] @relation("ApprovedByL2")
  actingLeaveAssignments LeaveRequest[] @relation("ActingLeaveApprover")
  payslips         Payslip[]
  attendanceSessions AttendanceSession[]
  locationPings      LocationPing[]
  exitRecords        ExitRecord[]   @relation("ExitEmployee")
  exitApprovalsAssigned ExitRecord[] @relation("ExitAssignedApprover")
  clearanceTasksAssigned ClearanceTask[] @relation("ClearanceAssignedManager")
  payrollAdjustments PayrollAdjustment[] @relation("AdjustmentEmployee")
  advanceLoans       SalaryAdvanceLoan[] @relation("LoanEmployee")
  documents          EmployeeDocument[]  @relation("DocumentEmployee")
  proTasks           ProTask[]           @relation("ProTaskEmployee")
  passwordResetTokens PasswordResetToken[]
  lateAttendanceWarnings LateAttendanceWarning[]
}

model LateAttendanceWarning {
  id         String    @id @default(cuid())
  employeeId String
  year       Int
  month      Int
  lateCount  Int       @default(0)
  emailedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year, month])
  @@index([year, month])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  employeeId String
  tokenHash  String
  purpose    String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, purpose, expiresAt])
}

model LeaveType {
  id                  String   @id @default(cuid())
  name                String   @unique
  code                String   @unique
  yearlyAllocation    Int
  maxCarryForward     Int      @default(60)
  requiresAttachment  Boolean  @default(false)
  paidLeave           Boolean  @default(true)
  balanceMode         String   @default("YEARLY")
  payRate             String   @default("FULL")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())

  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]
}

model LeaveBalance {
  id             String   @id @default(cuid())
  employeeId     String
  leaveTypeId    String
  year           Int
  openingBalance Float    @default(0)
  accrued        Float    @default(0)
  used           Float    @default(0)
  carryForward   Float    @default(0)

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id             String      @id @default(cuid())
  employeeId     String
  leaveTypeId    String
  startDate      DateTime
  endDate        DateTime
  days           Float
  reason         String
  attachmentUrl  String?
  status             String      @default("PENDING_L1")
  l1ApprovedById     String?
  l2ApprovedById     String?
  actingApproverId   String?
  actingAcceptedAt   DateTime?
  actingRejectedAt   DateTime?
  actingRejectReason String?
  airTicketEligible   Boolean   @default(false)
  airTicketFare       Float?
  payrollAdjustmentId String?   @unique
  approvedAt         DateTime?
  rejectedAt     DateTime?
  rejectReason   String?
  rejoiningDate              DateTime?
  statusAsOn                 String?
  leaveBalanceSnapshot       Float?
  currentLeaveBalanceSnapshot Float?
  extendedDays               Float          @default(0)
  remark                     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  employee       Employee  @relation("RequestedBy", fields: [employeeId], references: [id])
  leaveType      LeaveType @relation(fields: [leaveTypeId], references: [id])
  l1ApprovedBy   Employee? @relation("ApprovedByL1", fields: [l1ApprovedById], references: [id])
  l2ApprovedBy   Employee? @relation("ApprovedByL2", fields: [l2ApprovedById], references: [id])
  actingApprover Employee? @relation("ActingLeaveApprover", fields: [actingApproverId], references: [id])
  payrollAdjustment PayrollAdjustment? @relation(fields: [payrollAdjustmentId], references: [id], onDelete: SetNull)

  @@index([actingApproverId])
  @@index([status])
}

model Payslip {
  id                 String   @id @default(cuid())
  employeeId         String
  month              Int
  year               Int
  basic              Float
  housing            Float
  transport          Float
  overtime           Float
  deductions         Float
  netPay             Float
  createdAt          DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
}

model Office {
  id                 String              @id @default(cuid())
  name               String              @unique
  latitude           Float
  longitude          Float
  radiusMeters       Int                 @default(500)
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  employees          Employee[]
  attendanceSessions AttendanceSession[]
  locationPings      LocationPing[]
}

model AttendanceSession {
  id             String       @id @default(cuid())
  employeeId     String
  officeId       String?
  checkInAt      DateTime     @default(now())
  checkOutAt     DateTime?
  isActive       Boolean      @default(true)
  checkInMethod  String       @default("MANUAL")
  checkOutMethod String?
  isLateCheckIn  Boolean      @default(false)
  lastSeenAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  employee     Employee      @relation(fields: [employeeId], references: [id])
  office       Office?       @relation(fields: [officeId], references: [id])
  locationPings LocationPing[]

  @@index([employeeId, isActive])
  @@index([isActive, checkInAt])
}

model LocationPing {
  id             String             @id @default(cuid())
  employeeId     String
  sessionId      String?
  officeId       String?
  latitude       Float
  longitude      Float
  accuracy       Float?
  insideGeofence Boolean?
  geoTag         String?
  geoAddress     String?
  eventType      String             @default("PING")
  recordedAt     DateTime           @default(now())

  employee Employee           @relation(fields: [employeeId], references: [id])
  session  AttendanceSession? @relation(fields: [sessionId], references: [id])
  office    Office?           @relation(fields: [officeId], references: [id])

  @@index([employeeId, recordedAt])
  @@index([sessionId, recordedAt])
}

model ExitRecord {
  id                  String   @id @default(cuid())
  employeeId          String
  type                String // RESIGNATION | TERMINATION
  status              String   @default("PENDING")
  reasonCategory      String?
  reason              String?
  resignationDate     DateTime?
  requestedLastWorkingDay DateTime?
  lastWorkingDate     DateTime?
  noticePeriodDays      Int      @default(30)
  noticePeriodStartDate DateTime?
  noticeAccepted        Boolean  @default(true)
  noticeShortfallDays   Int      @default(0)
  assignedApproverId    String?
  negotiationNotes      String?
  supportingDocUrl    String?
  incidentNotes       String?
  employeeConfirmed   Boolean  @default(false)
  employeeConfirmedAt DateTime?
  lmApprovedById      String?
  lmApprovedAt        DateTime?
  hrApprovedById      String?
  hrApprovedAt        DateTime?
  ceoApprovedById     String?
  ceoApprovedAt       DateTime?
  rejectedById        String?
  rejectedAt          DateTime?
  rejectReason        String?
  exitInterviewNotes  String?
  experienceLetterIssuedAt DateTime?
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  employee          Employee         @relation("ExitEmployee", fields: [employeeId], references: [id])
  assignedApprover  Employee?        @relation("ExitAssignedApprover", fields: [assignedApproverId], references: [id])
  clearanceTasks    ClearanceTask[]
  finalSettlement   FinalSettlement?

  @@index([employeeId])
  @@index([status])
}

model ClearanceTask {
  id                 String   @id @default(cuid())
  exitRecordId       String
  department         String // HOD | IT | FINANCE | ADMIN | TRANSPORTATION | HR | PRO
  status             String   @default("PENDING") // PENDING | COMPLETED
  urgent             Boolean  @default(false)
  remarks            String?
  assignedManagerId  String?
  completedById      String?
  completedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  exitRecord       ExitRecord @relation(fields: [exitRecordId], references: [id], onDelete: Cascade)
  assignedManager  Employee?  @relation("ClearanceAssignedManager", fields: [assignedManagerId], references: [id])
  checklistItems   ClearanceChecklistItem[]

  @@index([exitRecordId])
  @@index([assignedManagerId])
}

model ClearanceChecklistItem {
  id              String   @id @default(cuid())
  clearanceTaskId String
  itemKey         String
  label           String
  status          String   @default("PENDING") // PENDING | COMPLETED | NOT_APPLICABLE
  remarks         String?
  completedById   String?
  completedAt     DateTime?
  sortOrder       Int      @default(0)
  amount          Float?
  adjustmentType  String?
  adjustmentCategory String?
  payrollAdjustmentId String? @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clearanceTask ClearanceTask @relation(fields: [clearanceTaskId], references: [id], onDelete: Cascade)
  payrollAdjustment PayrollAdjustment? @relation(fields: [payrollAdjustmentId], references: [id], onDelete: SetNull)

  @@unique([clearanceTaskId, itemKey])
  @@index([clearanceTaskId])
}

model PayrollAdjustment {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  employeeId      String
  type            String // ADDITION | DEDUCTION
  category        String
  glCode          String?
  amount          Float
  effectiveMonth  Int
  effectiveYear   Int
  reason          String
  supportingDocUrl String?
  recurring       Boolean  @default(false)
  frequency       String? // MONTHLY
  recurrenceEndMonth Int?
  recurrenceEndYear  Int?
  status          String   @default("DRAFT") // DRAFT | PENDING_L2 | APPROVED | REJECTED | PROCESSED
  requiresDualApproval Boolean @default(false)
  approver1Id     String?
  approver1At     DateTime?
  approver2Id     String?
  approver2At     DateTime?
  loanId          String?
  installmentNo   Int?
  createdById     String?
  approvedById    String?
  approvedAt      DateTime?
  rejectedById    String?
  rejectedAt      DateTime?
  rejectReason    String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee           @relation("AdjustmentEmployee", fields: [employeeId], references: [id])
  loan     SalaryAdvanceLoan? @relation(fields: [loanId], references: [id], onDelete: Cascade)
  clearanceChecklistItem ClearanceChecklistItem?
  leaveRequest LeaveRequest?

  @@index([employeeId, status])
  @@index([effectiveYear, effectiveMonth])
}

model SalaryAdvanceLoan {
  id               String   @id @default(cuid())
  employeeId       String
  type             String // ADVANCE | LOAN
  totalAmount      Float
  installmentAmount Float
  startMonth       Int
  startYear        Int
  recoveredAmount  Float    @default(0)
  reason           String
  supportingDocUrl String?
  status           String   @default("PENDING_FINANCE") // PENDING_FINANCE | PENDING_HR | ACTIVE | CLOSED | REJECTED
  requiresDualApproval Boolean @default(false)
  financeApprovedById String?
  financeApprovedAt   DateTime?
  financeApprovalNote String?
  hrApprovedById      String?
  hrApprovedAt        DateTime?
  hrApprovalNote      String?
  createdById      String?
  approver1Id      String?
  approver1At      DateTime?
  approver2Id      String?
  approver2At      DateTime?
  rejectedById     String?
  rejectedAt       DateTime?
  rejectReason     String?
  closedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee     Employee            @relation("LoanEmployee", fields: [employeeId], references: [id])
  installments PayrollAdjustment[]

  @@index([employeeId, status])
}

model EmployeeDocument {
  id               String   @id @default(cuid())
  employeeId       String
  docType          String // RESIDENCE_VISA | EMIRATES_ID | PASSPORT | LABOUR_PERMIT | HEALTH_CARD | MEDICAL_FITNESS | LABOUR_CONTRACT | ESTABLISHMENT_CARD | TRADE_LICENSE
  documentNumber   String?
  issuingAuthority String?
  issueDate        DateTime?
  expiryDate       DateTime?
  fileUrl          String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee Employee @relation("DocumentEmployee", fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([expiryDate])
}

model ProTask {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  employeeId      String
  taskType        String // NEW_VISA | RENEWAL | CANCELLATION
  documentType    String?
  status          String
  governmentRef   String?
  feeAmount       Float?
  notes           String?
  exitRecordId    String?
  documentId      String?
  autoCreated     Boolean  @default(false)
  submittedAt     DateTime?
  completedAt     DateTime?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation("ProTaskEmployee", fields: [employeeId], references: [id])

  @@index([employeeId, status])
  @@index([taskType, status])
}

model Attachment {
  id           String   @id @default(cuid())
  fileName     String
  mimeType     String
  sizeBytes    Int
  data         String?  @db.Text
  blobUrl      String?
  blobPathname String?
  category     String   @default("GENERAL")
  employeeId   String?
  employeeName String?
  employeeCode String?
  documentType String?
  contextLabel String?
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([employeeId])
  @@index([employeeCode])
  @@index([category])
}

model FinalSettlement {
  id              String   @id @default(cuid())
  exitRecordId    String   @unique
  yearsOfService  Float    @default(0)
  unpaidSalary    Float    @default(0)
  leaveEncashment Float    @default(0)
  gratuity        Float    @default(0)
  otherAdditions  Float    @default(0)
  deductions      Float    @default(0)
  netSettlement   Float    @default(0)
  breakdown       Json?
  status          String   @default("DRAFT") // DRAFT | FINALIZED
  computedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  exitRecord ExitRecord @relation(fields: [exitRecordId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  category    String
  label       String
  description String?
  updatedAt   DateTime @updatedAt
}

model RoleDefinition {
  id                      String   @id @default(cuid())
  code                    String   @unique
  label                   String
  description             String?
  assignable              Boolean  @default(true)
  isIndividualContributor Boolean  @default(false)
  canVoidActingColleague  Boolean  @default(false)
  allowedViews            Json
  sortOrder               Int      @default(0)
  active                  Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
